<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <NoWarn>$(NoWarn);NU1701</NoWarn>

    <AssemblyName>ApiarioRD</AssemblyName>
    <ApplicationIcon>imagens\iconeRD.ico</ApplicationIcon>

    <Product>ApiarioRD Sistemas</Product>
    <Description>Sistema de Gestão de Apiário</Description>
    <Version>1.0.0</Version>
    <RootNamespace>ApiarioRD</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="LiveChartsCore" Version="2.0.0" />
    <PackageReference Include="LiveChartsCore.SkiaSharpView" Version="2.0.0" />
    <PackageReference Include="LiveChartsCore.SkiaSharpView.WinForms" Version="2.0.0" />
  </ItemGroup>

  <!-- 🔥 GARANTE QUE O ÍCONE VÁ PARA O EXE -->
  <ItemGroup>
    <Content Include="imagens\iconeRD.ico">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>